[
  {
    "type": "console.model/metadata",
    "properties": {
      "model": {
        "group": "migration.openshift.io",
        "version": "v1alpha1",
        "kind": "VmwareCloudFoundationMigration"
      },
      "label": "VCF Migration",
      "labelPlural": "VCF Migrations",
      "abbr": "VCFM",
      "color": "#004B95"
    }
  },
  {
    "type": "console.navigation/section",
    "properties": {
      "id": "vcf-migration-section",
      "name": "VCF Migration",
      "perspective": "admin"
    }
  },
  {
    "type": "console.navigation/href",
    "properties": {
      "id": "vcf-migration-list",
      "name": "Migrations",
      "href": "/vcf-migration",
      "section": "vcf-migration-section",
      "perspective": "admin"
    }
  },
  {
    "type": "console.page/route",
    "properties": {
      "path": ["/vcf-migration"],
      "component": { "$codeRef": "migrationPlugin.MigrationListPage" },
      "exact": true
    }
  },
  {
    "type": "console.page/route",
    "properties": {
      "path": ["/vcf-migration/create"],
      "component": { "$codeRef": "migrationPlugin.MigrationWizard" }
    }
  },
  {
    "type": "console.page/route",
    "properties": {
      "path": ["/vcf-migration/ns/:ns/:name"],
      "component": { "$codeRef": "migrationPlugin.MigrationDetailPage" }
    }
  }
]
